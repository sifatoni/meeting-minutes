{
  "name": "minotaur",
  "version": "0.1.2",
  "description": "Offline Windows meeting recorder and minutes generator MVP starter.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main/main.js && node --check src/main/preload.js && node --check src/renderer/app.js",
    "dist": "electron-builder --win",
    "pack": "electron-builder --dir",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.minotaur.app",
    "productName": "Minotaur",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/mic.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "build/installer.nsh"
    },
    "asar": false,
    "files": [
      "src/**/*",
      "scripts/**/*",
      "assets/**/*",
      "package.json",
      "!.venv/**",
      "!.tmp/**",
      "!dist/**",
      "!docs/**",
      "!chrome-profile/**",
      "!meeting-minutes.zip"
    ]
  },
  "keywords": [
    "meeting-minutes",
    "offline",
    "electron",
    "windows"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "puppeteer": "^22.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
