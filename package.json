{
  "name": "offline-meeting-minutes",
  "version": "0.1.2",
  "description": "Offline Windows meeting recorder and minutes generator MVP starter.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main/main.js && node --check src/main/preload.js && node --check src/renderer/app.js",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.meetingminutes.app",
    "productName": "Meeting Minutes",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/mic.png"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/mic.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    },
    "asar": false,
    "files": [
      "**/*",
      "!.venv/**",
      "!.tmp/**",
      "!dist/**",
      "!docs/**"
    ]
  },
  "keywords": [
    "meeting-minutes",
    "offline",
    "electron",
    "windows"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
