{
  "name": "offline-meeting-minutes",
  "version": "0.1.0",
  "description": "Offline Windows meeting recorder and minutes generator MVP starter.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main/main.js && node --check src/main/preload.js && node --check src/renderer/app.js",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.meetingminutes.app",
    "productName": "Meeting Minutes",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": false
  },
  "keywords": [
    "meeting-minutes",
    "offline",
    "electron",
    "windows"
  ],
  "author": "",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  }
}
